pkgname="systemd"
pkgver="256.4"
pkgarch="x86_64-linux"
pkgdesc="System and service manager"
license="LGPL-2.1"

depends=("glibc" "dbus" "util-linux")
exports=(
    "bin/systemctl"
    "bin/journalctl"
    "bin/loginctl"
    "lib/systemd/systemd"
    "lib/systemd/systemd-journald"
