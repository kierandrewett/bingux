pkgscope="bingux"
pkgname="linux-kernel-full"
pkgver="6.14.6"
pkgarch="x86_64-linux"
pkgdesc="Linux kernel — Bingux defconfig with virtio/DRM/framebuffer support"
license="GPL-2.0"
depends=()
makedepends=()
exports=("boot/vmlinuz" "boot/config")
source=("https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-6.14.6.tar.xz")
sha256sums=("SKIP")

build() {
    cd "$SRCDIR/linux-6.14.6"

    # Start from defconfig (minimal, reliable)
    make defconfig

    # Enable hardware support needed for Bingux
    scripts/config --enable CONFIG_VIRTIO_PCI
    scripts/config --enable CONFIG_VIRTIO_BLK
    scripts/config --enable CONFIG_VIRTIO_NET
    scripts/config --enable CONFIG_VIRTIO_CONSOLE
    scripts/config --enable CONFIG_DRM
    scripts/config --enable CONFIG_DRM_VIRTIO_GPU
    scripts/config --enable CONFIG_FRAMEBUFFER_CONSOLE
    scripts/config --enable CONFIG_VT
    scripts/config --enable CONFIG_VT_CONSOLE
    scripts/config --enable CONFIG_INPUT_EVDEV
    scripts/config --enable CONFIG_DEVTMPFS
    scripts/config --enable CONFIG_DEVTMPFS_MOUNT
    scripts/config --enable CONFIG_TMPFS
    scripts/config --enable CONFIG_SERIAL_8250
    scripts/config --enable CONFIG_SERIAL_8250_CONSOLE
    scripts/config --enable CONFIG_EXT4_FS
    scripts/config --enable CONFIG_BLK_DEV_INITRD
    scripts/config --enable CONFIG_RD_GZIP
    scripts/config --enable CONFIG_MODULES
    scripts/config --enable CONFIG_NET
    scripts/config --enable CONFIG_INET
    scripts/config --disable CONFIG_WERROR
    make olddefconfig

    make -j$(nproc)
}

package() {
    cd "$SRCDIR/linux-6.14.6"
    mkdir -p "$PKGDIR/boot"
    cp arch/x86/boot/bzImage "$PKGDIR/boot/vmlinuz"
    cp .config "$PKGDIR/boot/config"
    # Install modules (if any built as modules)
    make INSTALL_MOD_PATH="$PKGDIR" modules_install 2>/dev/null || true
}
