pkgscope="bingux"
pkgname="busybox-src"
pkgver="1.37.0"
pkgarch="x86_64-linux"
pkgdesc="BusyBox — Swiss Army Knife of embedded Linux (host static binary)"
license="GPL-2.0"
depends=()
makedepends=()
exports=("bin/busybox" "bin/sh")
source=()
sha256sums=()

build() {
    # Use host busybox (already static-linked)
    cp "$(command -v busybox)" "$BUILDDIR/busybox"
}

package() {
    mkdir -p "$PKGDIR/bin"
    cp "$BUILDDIR/busybox" "$PKGDIR/bin/busybox"
    chmod +x "$PKGDIR/bin/busybox"
    # Create symlinks for all applets
    for cmd in $("$PKGDIR/bin/busybox" --list 2>/dev/null); do
        ln -sf busybox "$PKGDIR/bin/$cmd"
    done
}
