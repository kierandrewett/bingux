pkgscope="bingux"
pkgname="bxc"
pkgver="0.1.0"
pkgarch="x86_64-linux"
pkgdesc="Bingux cross-compilation shim"
license="MIT"

depends=("glibc")
exports=(
    "bin/bxc-shim"
)

source=()
sha256sums=()

build() {
    cargo build --release -p bxc-shim
}

package() {
    mkdir -p "$PKGDIR/bin"
    install -m755 "$BUILDDIR/target/release/bxc-shim" "$PKGDIR/bin/bxc-shim"
}
