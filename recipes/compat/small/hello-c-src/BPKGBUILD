pkgscope="bingux"
pkgname="hello-c-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="Hello world — compiled from C source inside Bingux"
license="MIT"

depends=("musl-toolchain-11.2.1")
makedepends=()

exports=("bin/hello-c")

source=()
sha256sums=()

build() {
    cat > "$SRCDIR/hello.c" << 'C'
#include <stdio.h>
#include <stdlib.h>

int fib(int n) {
    if (n <= 1) return n;
    return fib(n-1) + fib(n-2);
}

int main() {
    printf("Hello from Bingux!\n");
    printf("This program was compiled from C source.\n");
    printf("\nFibonacci: ");
    for (int i = 0; i < 10; i++) {
        printf("%d ", fib(i));
    }
    printf("\n");
    
    char *msg = malloc(64);
    if (msg) {
        sprintf(msg, "malloc works! (%p)", (void*)msg);
        printf("%s\n", msg);
        free(msg);
    }
    
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/hello-c" "$SRCDIR/hello.c"
}

package() {
    mkdir -p "$PKGDIR/bin"
    cp "$BUILDDIR/hello-c" "$PKGDIR/bin/hello-c"
    chmod +x "$PKGDIR/bin/hello-c"
}
