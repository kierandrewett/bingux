pkgscope="bingux"
pkgname="yes-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="yes — output a string repeatedly"
license="MIT"
depends=()
exports=("bin/bingux-yes")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/yes.c" << 'C'
#include <stdio.h>
int main(int argc, char *argv[]) {
    const char *s = argc > 1 ? argv[1] : "y";
    while (fputs(s, stdout) != EOF && putchar('\n') != EOF) {}
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-yes" "$SRCDIR/yes.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-yes" "$PKGDIR/bin/bingux-yes"; chmod +x "$PKGDIR/bin/bingux-yes"; }
