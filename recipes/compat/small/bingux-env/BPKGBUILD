pkgscope="bingux"
pkgname="bingux-env"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="env — run command with modified environment"
license="MIT"
depends=()
exports=("bin/bingux-env")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/env.c" << 'C'
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
extern char **environ;
int main(int argc, char *argv[]) {
    if (argc < 2) {
        for (char **e = environ; *e; e++) printf("%s\n", *e);
        return 0;
    }
    int i = 1;
    while (i < argc && strchr(argv[i], '=')) { putenv(argv[i]); i++; }
    if (i < argc) { execvp(argv[i], &argv[i]); perror(argv[i]); return 127; }
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-env" "$SRCDIR/env.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-env" "$PKGDIR/bin/bingux-env"; chmod +x "$PKGDIR/bin/bingux-env"; }
