pkgscope="bingux"
pkgname="pathutils"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="basename + dirname — path manipulation"
license="MIT"
depends=()
exports=("bin/bingux-basename" "bin/bingux-dirname")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/basename.c" << 'C'
#include <stdio.h>
#include <string.h>
#include <libgen.h>
int main(int argc, char *argv[]) {
    if (argc < 2) { fprintf(stderr, "usage: basename <path>\n"); return 1; }
    printf("%s\n", basename(argv[1]));
    return 0;
}
C
    cat > "$SRCDIR/dirname.c" << 'C'
#include <stdio.h>
#include <string.h>
#include <libgen.h>
int main(int argc, char *argv[]) {
    if (argc < 2) { fprintf(stderr, "usage: dirname <path>\n"); return 1; }
    printf("%s\n", dirname(argv[1]));
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-basename" "$SRCDIR/basename.c"
    bingux-gcc -o "$BUILDDIR/bingux-dirname" "$SRCDIR/dirname.c"
}
package() {
    mkdir -p "$PKGDIR/bin"
    cp "$BUILDDIR/bingux-basename" "$PKGDIR/bin/bingux-basename"
    cp "$BUILDDIR/bingux-dirname" "$PKGDIR/bin/bingux-dirname"
    chmod +x "$PKGDIR/bin/"*
}
