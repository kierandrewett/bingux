pkgscope="bingux"
pkgname="xxd-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="xxd — hex dump and reverse"
license="MIT"
depends=()
exports=("bin/xxd")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/xxd.c" << 'C'
#include <stdio.h>
#include <ctype.h>
#include <string.h>
int main(int argc, char *argv[]) {
    int reverse = 0;
    char *file = NULL;
    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-r") == 0) reverse = 1;
        else file = argv[i];
    }
    FILE *f = file ? fopen(file, reverse ? "r" : "rb") : stdin;
    if (!f) { perror(file); return 1; }
    if (reverse) {
        unsigned int byte;
        int col = 0;
        char line[256];
        while (fgets(line, sizeof(line), f)) {
            char *p = strchr(line, ':');
            if (!p) continue;
            p++;
            while (*p && *p != ' ' && *p != '\n') p++;
            while (*p == ' ') {
                if (sscanf(p, " %02x", &byte) == 1) { putchar(byte); p += 3; }
                else break;
            }
        }
    } else {
        unsigned char buf[16];
        int offset = 0, n;
        while ((n = fread(buf, 1, 16, f)) > 0) {
            printf("%08x: ", offset);
            for (int i = 0; i < n; i++) { printf("%02x", buf[i]); if (i%2==1) printf(" "); }
            for (int i = n; i < 16; i++) { printf("  "); if (i%2==1) printf(" "); }
            printf(" ");
            for (int i = 0; i < n; i++) printf("%c", isprint(buf[i]) ? buf[i] : '.');
            printf("\n");
            offset += n;
        }
    }
    if (f != stdin) fclose(f);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/xxd" "$SRCDIR/xxd.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/xxd" "$PKGDIR/bin/xxd"; chmod +x "$PKGDIR/bin/xxd"; }
