pkgscope="bingux"
pkgname="seq-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="seq — print sequence of numbers"
license="MIT"
depends=()
exports=("bin/bingux-seq")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/seq.c" << 'C'
#include <stdio.h>
#include <stdlib.h>
int main(int argc, char *argv[]) {
    double start = 1, step = 1, end;
    if (argc == 2) { end = atof(argv[1]); }
    else if (argc == 3) { start = atof(argv[1]); end = atof(argv[2]); }
    else if (argc == 4) { start = atof(argv[1]); step = atof(argv[2]); end = atof(argv[3]); }
    else { fprintf(stderr, "usage: seq [start] [step] end\n"); return 1; }
    for (double i = start; i <= end; i += step) printf("%.0f\n", i);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-seq" "$SRCDIR/seq.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-seq" "$PKGDIR/bin/bingux-seq"; chmod +x "$PKGDIR/bin/bingux-seq"; }
