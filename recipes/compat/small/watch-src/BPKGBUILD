pkgscope="bingux"
pkgname="watch-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="watch — execute a command periodically"
license="MIT"
depends=()
exports=("bin/bingux-watch")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/watch.c" << 'C'
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/wait.h>
#include <time.h>
int main(int argc, char *argv[]) {
    int interval = 2;
    int i = 1;
    if (i < argc && strcmp(argv[i], "-n") == 0) { i++; if (i < argc) { interval = atoi(argv[i]); i++; } }
    if (i >= argc) { fprintf(stderr, "usage: watch [-n sec] command [args...]\n"); return 1; }
    while (1) {
        printf("\033[2J\033[H"); // clear screen
        time_t t = time(NULL);
        printf("Every %ds: %s    %s\n\n", interval, argv[i], ctime(&t));
        fflush(stdout);
        pid_t pid = fork();
        if (pid == 0) { execvp(argv[i], &argv[i]); _exit(127); }
        waitpid(pid, NULL, 0);
        sleep(interval);
    }
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-watch" "$SRCDIR/watch.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-watch" "$PKGDIR/bin/bingux-watch"; chmod +x "$PKGDIR/bin/bingux-watch"; }
