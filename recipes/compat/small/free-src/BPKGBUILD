pkgscope="bingux"
pkgname="free-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="free — show memory usage"
license="MIT"
depends=()
exports=("bin/bingux-free")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/free.c" << 'C'
#include <stdio.h>
#include <sys/sysinfo.h>
int main() {
    struct sysinfo si;
    if (sysinfo(&si) != 0) return 1;
    long mb = 1024*1024;
    printf("              total        used        free\n");
    printf("Mem:    %10ld   %10ld   %10ld\n",
           si.totalram/mb, (si.totalram-si.freeram)/mb, si.freeram/mb);
    printf("Swap:   %10ld   %10ld   %10ld\n",
           si.totalswap/mb, (si.totalswap-si.freeswap)/mb, si.freeswap/mb);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-free" "$SRCDIR/free.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-free" "$PKGDIR/bin/bingux-free"; chmod +x "$PKGDIR/bin/bingux-free"; }
