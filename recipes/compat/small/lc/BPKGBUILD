pkgscope="bingux"
pkgname="lc"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="Line counter — counts lines, words, bytes"
license="MIT"
depends=()
exports=("bin/lc")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/lc.c" << 'C'
#include <stdio.h>
int main(int argc, char *argv[]) {
    FILE *f = argc > 1 ? fopen(argv[1], "r") : stdin;
    if (!f) { perror(argv[1]); return 1; }
    int lines = 0, words = 0, bytes = 0, in_word = 0, c;
    while ((c = fgetc(f)) != EOF) {
        bytes++;
        if (c == '\n') lines++;
        if (c == ' ' || c == '\n' || c == '\t') {
            in_word = 0;
        } else if (!in_word) {
            in_word = 1;
            words++;
        }
    }
    printf("%d lines, %d words, %d bytes\n", lines, words, bytes);
    if (f != stdin) fclose(f);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/lc" "$SRCDIR/lc.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/lc" "$PKGDIR/bin/lc"; chmod +x "$PKGDIR/bin/lc"; }
