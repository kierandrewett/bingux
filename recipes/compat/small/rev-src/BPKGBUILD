pkgscope="bingux"
pkgname="rev-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="rev — reverse lines"
license="MIT"
depends=()
exports=("bin/rev")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/rev.c" << 'C'
#include <stdio.h>
#include <string.h>
int main() {
    char line[4096];
    while (fgets(line, sizeof(line), stdin)) {
        int n = strlen(line);
        if (n > 0 && line[n-1] == '\n') { line[--n] = 0; }
        for (int i = n-1; i >= 0; i--) putchar(line[i]);
        putchar('\n');
    }
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/rev" "$SRCDIR/rev.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/rev" "$PKGDIR/bin/rev"; chmod +x "$PKGDIR/bin/rev"; }
