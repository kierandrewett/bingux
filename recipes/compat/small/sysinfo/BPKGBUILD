pkgscope="bingux"
pkgname="sysinfo"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="System information tool — shows Bingux system status"
license="MIT"

depends=()
exports=("bin/sysinfo")
source=()
sha256sums=()

build() {
    cat > "$SRCDIR/sysinfo.c" << 'C'
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/utsname.h>
#include <sys/sysinfo.h>
#include <unistd.h>

void print_line(const char *label, const char *value) {
    printf("  %-12s %s\n", label, value);
}

int main() {
    struct utsname un;
    struct sysinfo si;
    char buf[256];

    printf("\n  Bingux System Information\n");
    printf("  ========================\n\n");

    if (uname(&un) == 0) {
        print_line("Kernel:", un.release);
        print_line("Arch:", un.machine);
        print_line("Hostname:", un.nodename);
    }

    if (sysinfo(&si) == 0) {
        long mb = 1024 * 1024;
        snprintf(buf, sizeof(buf), "%ld MB total, %ld MB free",
                 si.totalram / mb, si.freeram / mb);
        print_line("Memory:", buf);

        snprintf(buf, sizeof(buf), "%ld seconds", si.uptime);
        print_line("Uptime:", buf);

        snprintf(buf, sizeof(buf), "%d", si.procs);
        print_line("Processes:", buf);
    }

    // Show package count
    int pkg_count = 0;
    char *store = getenv("BPKG_STORE_ROOT");
    if (store) {
        char cmd[512];
        snprintf(cmd, sizeof(cmd), "ls '%s' 2>/dev/null | wc -l", store);
        FILE *f = popen(cmd, "r");
        if (f) {
            fscanf(f, "%d", &pkg_count);
            pclose(f);
        }
    }
    snprintf(buf, sizeof(buf), "%d", pkg_count);
    print_line("Packages:", buf);

    printf("\n");
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/sysinfo" "$SRCDIR/sysinfo.c"
}

package() {
    mkdir -p "$PKGDIR/bin"
    cp "$BUILDDIR/sysinfo" "$PKGDIR/bin/sysinfo"
    chmod +x "$PKGDIR/bin/sysinfo"
}
