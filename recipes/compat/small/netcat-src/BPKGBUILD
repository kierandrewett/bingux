pkgscope="bingux"
pkgname="netcat-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="netcat — TCP/UDP networking tool"
license="MIT"
depends=()
exports=("bin/nc")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/nc.c" << 'C'
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <netdb.h>
#include <poll.h>

int main(int argc, char *argv[]) {
    int listen_mode = 0, port = 0;
    char *host = NULL;
    
    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "-l") == 0) listen_mode = 1;
        else if (strcmp(argv[i], "-p") == 0 && i+1 < argc) port = atoi(argv[++i]);
        else if (!host) host = argv[i];
        else port = atoi(argv[i]);
    }
    
    if (listen_mode) {
        int srv = socket(AF_INET, SOCK_STREAM, 0);
        int opt = 1;
        setsockopt(srv, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
        struct sockaddr_in addr = {.sin_family=AF_INET, .sin_port=htons(port), .sin_addr.s_addr=INADDR_ANY};
        bind(srv, (struct sockaddr*)&addr, sizeof(addr));
        listen(srv, 1);
        fprintf(stderr, "Listening on port %d...\n", port);
        int client = accept(srv, NULL, NULL);
        struct pollfd fds[2] = {{.fd=0,.events=POLLIN},{.fd=client,.events=POLLIN}};
        char buf[4096];
        while (poll(fds, 2, -1) > 0) {
            if (fds[0].revents & POLLIN) { int n=read(0,buf,sizeof(buf)); if(n<=0)break; write(client,buf,n); }
            if (fds[1].revents & POLLIN) { int n=read(client,buf,sizeof(buf)); if(n<=0)break; write(1,buf,n); }
        }
        close(client); close(srv);
    } else {
        if (!host || !port) { fprintf(stderr, "usage: nc [-l] host port\n"); return 1; }
        struct hostent *he = gethostbyname(host);
        if (!he) { fprintf(stderr, "resolve failed: %s\n", host); return 1; }
        int fd = socket(AF_INET, SOCK_STREAM, 0);
        struct sockaddr_in addr = {.sin_family=AF_INET, .sin_port=htons(port)};
        memcpy(&addr.sin_addr, he->h_addr, he->h_length);
        if (connect(fd, (struct sockaddr*)&addr, sizeof(addr)) < 0) { perror("connect"); return 1; }
        struct pollfd fds[2] = {{.fd=0,.events=POLLIN},{.fd=fd,.events=POLLIN}};
        char buf[4096];
        while (poll(fds, 2, -1) > 0) {
            if (fds[0].revents & POLLIN) { int n=read(0,buf,sizeof(buf)); if(n<=0)break; write(fd,buf,n); }
            if (fds[1].revents & POLLIN) { int n=read(fd,buf,sizeof(buf)); if(n<=0)break; write(1,buf,n); }
        }
        close(fd);
    }
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/nc" "$SRCDIR/nc.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/nc" "$PKGDIR/bin/nc"; chmod +x "$PKGDIR/bin/nc"; }
