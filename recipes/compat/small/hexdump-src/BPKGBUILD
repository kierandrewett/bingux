pkgscope="bingux"
pkgname="hexdump-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="hexdump — display file in hex"
license="MIT"
depends=()
exports=("bin/bingux-hexdump")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/hexdump.c" << 'C'
#include <stdio.h>
#include <ctype.h>
int main(int argc, char *argv[]) {
    FILE *f = argc > 1 ? fopen(argv[1], "rb") : stdin;
    if (!f) { perror(argv[1]); return 1; }
    unsigned char buf[16];
    int offset = 0, n;
    while ((n = fread(buf, 1, 16, f)) > 0) {
        printf("%08x  ", offset);
        for (int i = 0; i < 16; i++) {
            if (i < n) printf("%02x ", buf[i]); else printf("   ");
            if (i == 7) printf(" ");
        }
        printf(" |");
        for (int i = 0; i < n; i++)
            printf("%c", isprint(buf[i]) ? buf[i] : '.');
        printf("|\n");
        offset += n;
    }
    printf("%08x\n", offset);
    if (f != stdin) fclose(f);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-hexdump" "$SRCDIR/hexdump.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-hexdump" "$PKGDIR/bin/bingux-hexdump"; chmod +x "$PKGDIR/bin/bingux-hexdump"; }
