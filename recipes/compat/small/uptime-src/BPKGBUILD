pkgscope="bingux"
pkgname="uptime-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="uptime — show system uptime and load"
license="MIT"
depends=()
exports=("bin/bingux-uptime")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/uptime.c" << 'C'
#include <stdio.h>
#include <sys/sysinfo.h>
#include <time.h>
int main() {
    struct sysinfo si;
    if (sysinfo(&si) != 0) { perror("sysinfo"); return 1; }
    int days = si.uptime / 86400;
    int hours = (si.uptime % 86400) / 3600;
    int mins = (si.uptime % 3600) / 60;
    time_t t = time(NULL);
    struct tm *tm = localtime(&t);
    printf(" %02d:%02d:%02d up ", tm->tm_hour, tm->tm_min, tm->tm_sec);
    if (days) printf("%d day%s, ", days, days > 1 ? "s" : "");
    printf("%d:%02d, ", hours, mins);
    printf(" load average: %.2f, %.2f, %.2f\n",
           si.loads[0] / 65536.0, si.loads[1] / 65536.0, si.loads[2] / 65536.0);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-uptime" "$SRCDIR/uptime.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-uptime" "$PKGDIR/bin/bingux-uptime"; chmod +x "$PKGDIR/bin/bingux-uptime"; }
