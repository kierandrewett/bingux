pkgscope="bingux"
pkgname="strings-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="strings — find printable strings in files"
license="MIT"
depends=()
exports=("bin/bingux-strings")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/strings.c" << 'C'
#include <stdio.h>
#include <ctype.h>
int main(int argc, char *argv[]) {
    int min_len = 4;
    FILE *f = argc > 1 ? fopen(argv[1], "rb") : stdin;
    if (!f) { perror(argv[1]); return 1; }
    char buf[4096];
    int len = 0;
    int c;
    while ((c = fgetc(f)) != EOF) {
        if (isprint(c) || c == '\t') {
            if (len < sizeof(buf)-1) buf[len++] = c;
        } else {
            if (len >= min_len) { buf[len] = 0; puts(buf); }
            len = 0;
        }
    }
    if (len >= min_len) { buf[len] = 0; puts(buf); }
    if (f != stdin) fclose(f);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-strings" "$SRCDIR/strings.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-strings" "$PKGDIR/bin/bingux-strings"; chmod +x "$PKGDIR/bin/bingux-strings"; }
