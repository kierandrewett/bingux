pkgscope="bingux"
pkgname="hostname-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="hostname — get/set hostname"
license="MIT"
depends=()
exports=("bin/hostname")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/hostname.c" << 'C'
#include <stdio.h>
#include <string.h>
#include <unistd.h>
int main(int argc, char *argv[]) {
    if (argc > 1) { sethostname(argv[1], strlen(argv[1])); return 0; }
    char buf[256]; gethostname(buf, sizeof(buf)); printf("%s\n", buf);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/hostname" "$SRCDIR/hostname.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/hostname" "$PKGDIR/bin/hostname"; chmod +x "$PKGDIR/bin/hostname"; }
