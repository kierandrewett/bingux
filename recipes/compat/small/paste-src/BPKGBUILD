pkgscope="bingux"
pkgname="paste-src"
pkgver="1.0.0"
pkgarch="x86_64-linux"
pkgdesc="paste — merge lines of files"
license="MIT"
depends=()
exports=("bin/bingux-paste")
source=()
sha256sums=()
build() {
    cat > "$SRCDIR/paste.c" << 'C'
#include <stdio.h>
#include <string.h>
int main(int argc, char *argv[]) {
    char *delim = "\t";
    FILE *files[64]; int nf = 0;
    for (int i = 1; i < argc && nf < 64; i++) {
        if (strcmp(argv[i], "-d") == 0 && i+1 < argc) { delim = argv[++i]; continue; }
        files[nf] = fopen(argv[i], "r");
        if (files[nf]) nf++;
    }
    if (nf == 0) { files[0] = stdin; nf = 1; }
    char lines[64][4096];
    int done;
    do {
        done = 1;
        for (int i = 0; i < nf; i++) {
            if (fgets(lines[i], sizeof(lines[i]), files[i])) {
                lines[i][strcspn(lines[i], "\n")] = 0;
                done = 0;
            } else lines[i][0] = 0;
        }
        if (!done) {
            for (int i = 0; i < nf; i++) { if (i) fputs(delim, stdout); fputs(lines[i], stdout); }
            putchar('\n');
        }
    } while (!done);
    for (int i = 0; i < nf; i++) if (files[i] != stdin) fclose(files[i]);
    return 0;
}
C
    bingux-gcc -o "$BUILDDIR/bingux-paste" "$SRCDIR/paste.c"
}
package() { mkdir -p "$PKGDIR/bin"; cp "$BUILDDIR/bingux-paste" "$PKGDIR/bin/bingux-paste"; chmod +x "$PKGDIR/bin/bingux-paste"; }
